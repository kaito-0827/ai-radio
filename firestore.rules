rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Custom nested path for AI Radio in Firestore
    match /artifacts/ai-radio-default/public/data/letters/{document} {
      allow read, write: if true; // Allows guest letters submission and retrieval
    }
    match /artifacts/ai-radio-default/public/data/chats/{document} {
      allow read, write: if true; // Allows open live chat reading and writing
    }
    // Shared broadcast timeline (segments + audio chunks subcollections)
    match /artifacts/ai-radio-default/public/data/broadcast/{document=**} {
      allow read, write: if true;
    }
    // Producer lease for leader election
    match /artifacts/ai-radio-default/public/data/broadcast_meta/{document} {
      allow read, write: if true;
    }
    // Breaking-news dedupe records
    match /artifacts/ai-radio-default/public/data/broadcast_news/{document} {
      allow read, write: if true;
    }
    // Active listener heartbeats used by the VPS worker to pause when nobody is tuned in
    match /artifacts/ai-radio-default/public/data/listener_presence/{document} {
      allow read, write: if true;
    }
  }
}
